<launch>
  <arg name="use_sim_time" default="false" />
  <arg name="namespace" default=""
       description="must provide empty or absolute namespace because: https://github.com/ros2/launch_ros/issues/428"
       />
  <arg name="config_fname" default="$(find-pkg-share slam3d_ros2)/config/defaults.yaml" />
  <arg name="cloud_topic" default="/velodyne_points" />
  <arg name="cloud_frame" default="velodyne_link" />
  <arg name="odom_frame" default="odom" />
  <arg name="map_frame" default="map" />
  <arg name="base_frame" default="base_link" />
  <arg name="use_external_component_container" default="false" />
  <arg name="external_component_container" default="" />

  <let
      if="$(var use_external_component_container)"
      name="fully_qualified_component_container_name"
      value="$(var external_component_container)"
      />
  <node
      unless="$(var use_external_component_container)"
      pkg="rclcpp_components"
      exec="component_container_mt"
      name="component_container"
      namespace="$(var namespace)"
      />
  <let
      unless="$(var use_external_component_container)"
      name="fully_qualified_component_container_name"
      value="$(var namespace)/component_container"
      />

  <load_composable_node target="$(var fully_qualified_component_container_name)">
    <composable_node
        pkg="slam3d_ros2"
        plugin="slam3d::PointcloudMapper"
        name="slam3d"
        namespace="$(var namespace)"
        >
      <param from="$(var config_fname)" />
      <param name="use_sim_time" value="$(var use_sim_time)" />
      <param name="laser_frame"    value="$(var cloud_frame)" />
      <param name="robot_frame" value="$(var base_frame)" />
      <param name="odometry_frame" value="$(var odom_frame)" />
      <param name="map_frame" value="$(var map_frame)" />

      <remap from="scan" to="$(var cloud_topic)" />

    </composable_node>

  </load_composable_node>

</launch>
